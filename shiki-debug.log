<pre class="shiki github-dark-dimmed" style="background-color:#22272e;color:#adbac7"><code>&quot;use client&quot;;

import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from &quot;@/components/ui/table&quot;;
import { Badge } from &quot;@/components/ui/badge&quot;;

const data = [
  { id: &quot;1&quot;, name: &quot;Invoices&quot;, status: &quot;Paid&quot;, amount: &quot;$250.00&quot;, method: &quot;PayPal&quot; },
  { id: &quot;2&quot;, name: &quot;Subscriptions&quot;, status: &quot;Pending&quot;, amount: &quot;$150.00&quot;, method: &quot;Credit Card&quot; },
  { id: &quot;3&quot;, name: &quot;Taxes&quot;, status: &quot;Unpaid&quot;, amount: &quot;$350.00&quot;, method: &quot;Bank Transfer&quot; },
];

export default function ResponsiveTableDemo() {
  return (
    &lt;div className=&quot;space-y-8 w-full&quot;&gt;
      &lt;div&gt;
        &lt;h3 className=&quot;text-lg font-medium mb-4&quot;&gt;1. Horizontal Scroll (Standard)&lt;/h3&gt;
        &lt;div className=&quot;rounded-md border overflow-x-auto&quot;&gt;
          &lt;Table className=&quot;min-w-[600px]&quot;&gt;
            &lt;TableHeader&gt;
              &lt;TableRow&gt;
                &lt;TableHead&gt;Name&lt;/TableHead&gt;
                &lt;TableHead&gt;Status&lt;/TableHead&gt;
                &lt;TableHead&gt;Method&lt;/TableHead&gt;
                &lt;TableHead className=&quot;text-right&quot;&gt;Amount&lt;/TableHead&gt;
              &lt;/TableRow&gt;
            &lt;/TableHeader&gt;
            &lt;TableBody&gt;
              {data.map((item) =&gt; (
                &lt;TableRow key={item.id}&gt;
                  &lt;TableCell className=&quot;font-medium&quot;&gt;{item.name}&lt;/TableCell&gt;
                  &lt;TableCell&gt;&lt;Badge variant=&quot;outline&quot;&gt;{item.status}&lt;/Badge&gt;&lt;/TableCell&gt;
                  &lt;TableCell&gt;{item.method}&lt;/TableCell&gt;
                  &lt;TableCell className=&quot;text-right&quot;&gt;{item.amount}&lt;/TableCell&gt;
                &lt;/TableRow&gt;
              ))}
            &lt;/TableBody&gt;
          &lt;/Table&gt;
        &lt;/div&gt;
      &lt;/div&gt;

      &lt;div&gt;
        &lt;h3 className=&quot;text-lg font-medium mb-4&quot;&gt;2. Card View (Mobile Optimized)&lt;/h3&gt;
        &lt;div className=&quot;grid gap-4 md:hidden&quot;&gt;
          {data.map((item) =&gt; (
            &lt;div key={item.id} className=&quot;border rounded-lg p-4 space-y-2&quot;&gt;
              &lt;div className=&quot;flex justify-between items-center&quot;&gt;
                &lt;span className=&quot;font-bold&quot;&gt;{item.name}&lt;/span&gt;
                &lt;Badge&gt;{item.status}&lt;/Badge&gt;
              &lt;/div&gt;
              &lt;div className=&quot;flex justify-between text-sm text-muted-foreground&quot;&gt;
                &lt;span&gt;Method: {item.method}&lt;/span&gt;
                &lt;span className=&quot;font-medium text-foreground&quot;&gt;{item.amount}&lt;/span&gt;
              &lt;/div&gt;
            &lt;/div&gt;
          ))}
        &lt;/div&gt;
        &lt;div className=&quot;hidden md:block text-muted-foreground text-sm italic&quot;&gt;
          Resize to mobile view to see the Card Layout.
        &lt;/div&gt;
      &lt;/div&gt;

      &lt;div&gt;
        &lt;h3 className=&quot;text-lg font-medium mb-4&quot;&gt;3. Column Priority (Selective Visibility)&lt;/h3&gt;
        &lt;div className=&quot;rounded-md border&quot;&gt;
          &lt;Table&gt;
            &lt;TableHeader&gt;
              &lt;TableRow&gt;
                &lt;TableHead&gt;Name&lt;/TableHead&gt;
                &lt;TableHead className=&quot;hidden sm:table-cell&quot;&gt;Status&lt;/TableHead&gt;
                &lt;TableHead className=&quot;hidden lg:table-cell&quot;&gt;Method&lt;/TableHead&gt;
                &lt;TableHead className=&quot;text-right&quot;&gt;Amount&lt;/TableHead&gt;
              &lt;/TableRow&gt;
            &lt;/TableHeader&gt;
            &lt;TableBody&gt;
              {data.map((item) =&gt; (
                &lt;TableRow key={item.id}&gt;
                  &lt;TableCell className=&quot;font-medium&quot;&gt;
                    {item.name}
                    &lt;div className=&quot;sm:hidden text-xs text-muted-foreground&quot;&gt;
                      {item.status}
                    &lt;/div&gt;
                  &lt;/TableCell&gt;
                  &lt;TableCell className=&quot;hidden sm:table-cell&quot;&gt;
                    &lt;Badge variant=&quot;outline&quot;&gt;{item.status}&lt;/Badge&gt;
                  &lt;/TableCell&gt;
                  &lt;TableCell className=&quot;hidden lg:table-cell&quot;&gt;{item.method}&lt;/TableCell&gt;
                  &lt;TableCell className=&quot;text-right&quot;&gt;{item.amount}&lt;/TableCell&gt;
                &lt;/TableRow&gt;
              ))}
            &lt;/TableBody&gt;
          &lt;/Table&gt;
        &lt;/div&gt;
        &lt;p className=&quot;text-sm text-muted-foreground mt-2 italic&quot;&gt;
          * Status is hidden on XS, Method is hidden on SM/MD screens.
        &lt;/p&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  );
}
